;P2 Hit by Parry
[Statedef 2500]
type = A
movetype = H
physics = N
anim = 5030

[State -3, GetHit Snd]
type=playsnd
trigger1 = Time = 0
value = 5000,1+(random%5)
ignorehitpause = 1

[State 13200, Anim]
type = ChangeAnim
trigger1 = Time = 0
value = ifelse(selfanimexist(5052),5052,5030)

[State 182, 1]
type = screenbound
trigger1 = 1
movecamera = 0,0
value = 0


[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1

[State 0, VelSet]
type = VelSet
trigger1 = 1
x = -20
y = -2


[State 0, Gravity]
type = Gravity
trigger1 = time > 80



[State 0, Send P1 Into Invisible]
type = Null
triggerall = time >= 2
triggerall = playeridexist(ceil((gethitvar(fall.envshake.ampl))))
triggerall = playerid(ceil(gethitvar(fall.envshake.ampl))), var(50) >= 45
trigger1 = BackEdgeDist <= -20
trigger1 = 1 || playerid(ceil(gethitvar(fall.envshake.ampl))),cond(1,var(53) := (var(53)|32),0) ;Make P1 Invisible


[State 0, Go Into Next Scene]
type = ChangeState
trigger1 = playeridexist(ceil((gethitvar(fall.envshake.ampl))))
trigger1 = playerid(ceil(gethitvar(fall.envshake.ampl))),stateno = 2900
value = stateno+1
ctrl = 0

