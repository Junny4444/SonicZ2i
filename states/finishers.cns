;Mash digits var thing
[statedef 33085]
type = A
movetype = I
physics = n
anim = 1

[State init]
type = null
triggerall = !var(0)
trigger1 = 1 || var(0) := root,id
trigger1 = 1 || var(1) := parent,id
trigger1 = 1 || var(2) := parent,var(8) ;Keep track of number of times mashed
;var(3) is the "id" of each digit, 0 being being the left, 1 being the right
;POS
trigger1 = 1 || fvar(0) := floor(gamewidth/2)
trigger1 = 1 || fvar(1) := floor(gameheight/2)
persistent = 0

[State track digit values]
type = null
triggerall = root,time < 220
;Var(10)/11 are the raw number of each digit
trigger1 = 1 || var(10) := floor(var(2)/10)
trigger1 = 1 || var(11) := cond(var(2) > 0,floor(var(2)%10),0)
;Var(20)/21 are the anim number of each digit
trigger1 = 1 || var(20) := 33085 + var(10)
trigger1 = 1 || var(21) := 33085 + var(11)

[State remove digits]
type = removeexplod
trigger1 = var(5) && numexplod(stateno+var(3))
id = stateno + var(3)

[State Spawn Upper Digits]
type = explod
triggerall = root,time < 220
trigger1 = !var(5)
trigger1 = !numexplod(stateno+var(3))
trigger1 = cond(var(3),1,(var(2) >= 10))
id = stateno + var(3)
anim = var(20+var(3))
pos = floor(fvar(0))+(10*var(3)),floor(fvar(0))
postype = left
removetime = -1
bindtime = -1
ontop = 1

[State Set to loop again]
type = varset
triggerall = root,time < 220
triggerall = !var(30)
triggerall = playeridexist(var(1))
;Despawn digits
trigger1 = var(2) != parent,var(8) && !var(5)
trigger1 = 1 || var(3) := -1 || var(5) := 1
;spawn digits again
trigger2 = var(5) && var(3) >= 1
trigger2 = 1 || var(3) := -1 || var(5) := 0
var(2) = parent,var(8)

[State end] 
type = varset
trigger1 = !playeridexist(var(1)) && !var(30)
trigger1 = 1 || var(3) := -1 || var(5) := 1
var(30) = 1

[State recursion]
type = changestate
triggerall = var(3) < 1
trigger1 = 1 || var(3) := var(3) + 1
value = stateno

[State end]
type = destroyself
trigger1 = var(30) && var(3) > 1 && var(5)
trigger2 = !playeridexist(var(1))
trigger3 = root,stateno != 3301
