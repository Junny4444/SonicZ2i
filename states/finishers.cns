trigger1 = 1 || playerid(ceil(gethitvar(fall.envshake.ampl))),cond(1,var(53) := var(53) - (var(53)&32),0) 
trigger1 = 1 || playerid(ceil(gethitvar(fall.envshake.ampl))),cond(1,var(50) := 0,0) 
persistent = 0
ignorehitpause = 1


[State 0, NotHitBy]
