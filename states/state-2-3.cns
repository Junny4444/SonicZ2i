;==========================================================
[Statedef -3]

;Timer is frozen when you perform supermoves.
;So you won't have "Time Over!" while attacking the enemy.
;[State -3, AssertSpecial]
;type        = AssertSpecial
;triggerall    = !WinKO            ;remember to put this otherwise no winpose after the supermove!
;;trigger1        = StateNo = [2710, 2795]
;trigger1        = StateNo = [2000, 2900]
;ignorehitpause    = 1
;persistent    = 1
;flag        = TimerFreeze
;==========================================================

;This controller plays a sound everytime the player lands from a jump, or from a back-dash.
[State -3, Landing Sound]
type = PlaySnd
triggerall = Time = 1
trigger1 = StateNo = 52 ;Jump land
trigger2 = StateNo = 0 && PrevStateNo = 5120
trigger3 = StateNo = 5201
trigger4 = StateNo = 52000
trigger5 = stateno = 2115
trigger6 = stateno = 52005
trigger7 = stateno = 52010
trigger8 = stateno = 52015
value = 40, 0

[state 52, Land FX]
type = helper
triggerall = Time = 1
trigger1 = StateNo = 52
trigger2 = StateNo = 5201
trigger3 = StateNo = 52000
trigger4 = stateno = 2115
trigger5 = stateno = 52005
trigger6 = stateno = 52010
trigger7 = stateno = 52015
name = "LandFX"
StateNo = 17100
id = 17100
postype = P1
ownpal = 1
keyctrl = 0
supermovetime = 99999
pausemovetime = 99999

[State 0, Recover Pulse]
type = Helper
triggerall = !numHelper(52100)
trigger1 = StateNo = 5201
name = "recoverpulser"
ID = 52100
StateNo = 52100
ownpal = 1
supermovetime = 99999
pausemovetime = 99999


;--------------------------------------

[State -3, GetHitSnd Light]
type = PlaySnd
triggerall = alive && (time = 1)
triggerall = StateNo = 5000||StateNo = 5010||StateNo = 5020||StateNo = 5070||StateNo = 5080
trigger1 = NumEnemy > 0
trigger1 = enemynear,hitdefattr = SCA,SA,HA
trigger2 = GetHitVar(animtype)=0 && random<250
value = s5000,0+random%4
channel = 0
ignorehitpause = 1
persistent = 0
volumescale = 200

[State -3, GetHitSnd Medium]
type = PlaySnd
triggerall = alive && (time = 1)
triggerall = StateNo = 5000||StateNo = 5010||StateNo = 5020||StateNo = 5070||StateNo = 5080
trigger1 = NumEnemy > 0
trigger1 = enemynear,hitdefattr = SCA,SA,HA
trigger2 = GetHitVar(animtype)=1 && random<375
value = s5000,10+random%3
channel = 0
ignorehitpause = 1
persistent = 0
volumescale = 200

[State -3, GetHitSnd Hard]
type = PlaySnd
triggerall = alive && (time = 1)
triggerall = StateNo = 5000||StateNo = 5010||StateNo = 5020||StateNo = 5070||StateNo = 5080
trigger1 = NumEnemy > 0
trigger1 = enemynear,hitdefattr = SCA,SA,HA
trigger2 = GetHitVar(animtype)>=2 && random<500
value = s5000,20+random%4
channel = 0
ignorehitpause = 1
persistent = 0
volumescale = 200


[State 0, Stop Ring Burst Music]
type = StopSnd
trigger1 = stateno != 2405
channel = 25

[State 0, Ring Burst End Sound]
type = PlaySnd
triggerall = (var(42)&16384) != 0 ;Bit is ON
trigger1 = stateno != 2405
trigger1 = 1 || var(42) := var(42) - (var(42)&16384)
value = S2400,1
;--------------------------------------

[state -3, remove afterimage]
type = afterimagetime
triggerall = (var(42)&4) = 0 ;Speed Boost
trigger1 = Movetype = H
trigger2 = StateNo != [10230,10233]  	;Super Jump
;trigger2 = StateNo != [110,118]  		;air dash
trigger2 = StateNo != 50
trigger2 = stateno != [1002,1005] ;Lightspeed Dash
trigger2 = stateno != [1201,1208] ;Homing Attack
trigger2 = stateno != [1103,1104] ;EX Spindash
trigger2 = stateno != 1510 ;Air Trick Attack EX
trigger2 = stateno != [2676,2679] ;En Homing Attack
trigger2 = stateno != 2205 ;Lvl 2 Sonic Wind
trigger2 = stateno != 2405 ;Ring Burst
trigger2 = stateno != 2000 ;Sonic Wind
time = 0

[State -3, Prevent Crossup]
type = width
triggerall = NumEnemy
trigger1 = movetype != H
trigger1 = facing != enemynear, facing
edge = 4, 0
ignorehitpause = 1

[State -3, No walk during turning animation]
type = VelSet
trigger1 = anim=5
x = 0




;===============================================================================
; Slashing Chop / Saving Strike code (Part B)
;===============================================================================
[state -3, animelem set]
type = VarSet
trigger1 = StateNo = 1300 
var(23) = animelemno(0)

 
[State -3, Change to second state]
type = HitOverride
trigger1 = StateNo = 1300
attr = SCA,NA,SA,HA,NP,SP,HP
slot = 0
StateNo = 1301
time = 1
forceair = 0
ignorehitpause = 1
persistent = 1
 
[state -3, VarSet for first state]
type = VarSet
trigger1 = StateNo = 1300
var(20) = 1
 
[state -3, VarSet for second state]
type = VarSet
trigger1 = StateNo = 1301
var(20) = 0

[State -3, health removal in second state]
type = LifeAdd
trigger1 = StateNo = 1301
value = -(GetHitVar(damage))
kill = 1

;guard string penalty
[State 0, TargetPowerAdd]
type = TargetPowerAdd
trigger1 = NumHelper(90000005)
trigger1 = helper(90000005),Var(2)>0
trigger1 = NumTarget
trigger1 = target, StateNo = [130,155]
trigger1 = target, MoveType = H
value = 2
ignorehitpause = 1

;================================================================================
; ------- Cheap K.O. system By Warusaki3 & POTS --------
;===============================================================================



[State -3, Cheap KO]
type = changestate
trigger1 = !alive && (StateNo = [5000, 5010])
trigger1 = PrevStateNo = 120 || (PrevStateNo = [130, 131]) || (PrevStateNo = [140, 141]) || (PrevStateNo = [150, 153])
value = 5950
ignorehitpause = 1


[State -2,KO]
type = VarSet
triggerall = StateNo = [120,159]
trigger1 = StateType = S
ignorehitpause = 1
fvar(1) = 0

[State -2,KO]
type = VarSet
triggerall = StateNo = [120,159]
trigger1 = StateType = C
ignorehitpause = 1
fvar(1) = 1

[State -2,KO]
type = VarSet
triggerall = StateNo = [120,159]
trigger1 = StateType = A
ignorehitpause = 1
fvar(1) = 2

[State -3, Variable Height]
type= playerpush
triggerall= statetype=A && movetype!=H && numenemy
triggerall= p2bodydist x = [-(enemynear,const(size.ground.back) + enemynear,const(size.ground.front)), 0]; checks if both characters are within each other's width
trigger1= p2statetype=S
trigger1= p2dist y >= (enemynear,const(size.height) )
trigger2= p2statetype=C
trigger2= p2dist y >= (enemynear,const(size.height) - 48)
trigger3= p2statetype=L
trigger3= p2dist y >= 11
value= 0
ignorehitpause= 1


[State 0, Ai Random Var]
type = VarSet
trigger1 = Ailevel
var(48) = random%1000




;================================================================================
; ------- Finisher SCTRLS --------
;===============================================================================

[State 0, Be Invisible if Win with Level 3]
type = AssertSpecial
trigger1 = numhelper(3313) ;Copy of Sonic that does the winpose
flag = Invisible
flag2 = Noshadow

[State 0, Win with Level 3 Screenbound]
type = ScreenBound
trigger1 = numhelper(3313) ;Copy of Sonic that does the winpose
value = 1
movecamera = 0,0


[State 0, Reset Emo after Parry]
type = VarSet
triggerall = (var(42)&131072) != 0 ;Bit is ON
trigger1 = stateno != 2300 ;Parry 
trigger1 = stateno != 2350 ;Parry Activate
trigger1 = 1 || var(42) := var(42) - (var(42)&131072)
var(51) = 0
ignorehitpause = 1


[State 0, Finisher Turn off Music]
type = AssertSpecial
trigger1 = stateno = [3301,3311]
trigger2 = numhelper(3313) ;Copy of Sonic that does the winpose
flag = Nomusic

[State 0, Finisher Music]
type = PlaySnd
triggerall = (var(42)&65536) = 0 ;Finisher Music has not played yet
trigger1 = stateno = [3301,3311]
trigger1 = 1 || var(42) := var(42) + 65536*((var(42)&65536)=0)
value = 9000,cond(var(59) != 99999,var(59),random%11)
channel = 31


[State 0, Reset Finisher SND Bit]
type = Null
trigger1 = stateno != [3301,3311]
trigger1 = 1 || var(42) := var(42) - (var(42)&65536)
ignorehitpause = 1


