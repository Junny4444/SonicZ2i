postype = left
name = "Lightspeed Gauge"
id = 2751
size.xscale = 1
size.yscale = 1
stateno = 2751
ownpal = 1
ignorehitpause = 1
pausemovetime = 999999
supermovetime = 999999


[State 0, Keep Emo on win]
type = VarSet
triggerall = var(51) = 1
triggerall = Roundstate = 4
trigger1 = Alive 
var(51) = 1
ignorehitpause = 1
persistent = 1

[State 0, Keep Emo bar on win]
type = VarSet
triggerall = var(51) = 1
triggerall = Roundstate = 4
trigger1 = Alive 
var(52) = var(52)
ignorehitpause = 1
persistent = 1

[State 0, Lose Emo Bar on Death]
type = VarSet
triggerall = var(51) = 1
triggerall = Roundstate = 4
trigger1 = !Alive 
var(52) = 0
ignorehitpause = 1
persistent = 1


[State 0, Lose Emo on Death]
type = VarSet
triggerall = var(51) = 1
triggerall = Roundstate = 4
trigger1 = !Alive 
var(51) = 0
ignorehitpause = 1
persistent = 1


[State 0, Keep Lightspeed on win]
type = VarSet
trigger1 = Roundstate = [3,4] 
trigger1 = Alive
var(2) = var(2)
ignorehitpause = 1
persistent = 1


[State 0, Lose Lightspeed on death]
type = VarSet
trigger1 = Roundstate = [3,4]  
trigger1 = !Alive
var(2) = 0
ignorehitpause = 1
persistent = 1


[State 0, Deplete Emo Bar on Exit]
type = VarAdd
triggerall = gametime%cond((var(42)&256) != 0, 2,7) = 0
;triggerall = (var(42)&256) = 0 && gametime%6 = 0 || (var(42)&256) != 0 && gametime%2 = 0
triggerall = stateno != 2650 ;Gem Prep
triggerall = var(43) ;Gem is Active
trigger1 = var(52) >= 0
var(52) = cond((var(42)&256) != 0, -2,-1)

[State 0, Turn off Emo if Bar Empty or Round end in exit]
type = VarSet
trigger1 = var(52) < 0
trigger2 = roundstate != 2 && var(43)
var(51) = 0


[State 0, Turn off Gem if No Emo or round end]
type = VarSet
trigger1 = !var(51) 
trigger2 = roundstate != 2 
var(43) = 0


[State 0, Turn off Electric Shield Flag]
type = Null
triggerall = (var(42)&256) != 0
trigger1 = !var(51)
trigger1 = 1 || var(42) := var(42) - (var(42)&256)
trigger2 = movetype = H && stateno != 3107 && stateno != [120,155] 
trigger2 = stateno != [5000,5100]
trigger2 = 1 || var(42) := var(42) - (var(42)&256)

[State 0, Ring Spawn with Elec Shield]
type = Helper
triggerall = Numhelper(2669) ;Electric Shield
triggerall = Numhelper(2670) < 5 ;Rings
trigger1 = random%999 = [0,15]
stateno = 2670
ID = 2670
name = "Ring"
postype = P1
pos = 0,0
ownpal = 1

[State 0, Electric Shield Ring Lifeadd]
type = LifeAdd
trigger1 = var(40) 
value = 30
kill = 0
absolute = 1

[State -2, Play Ring SND]
type = playsnd
trigger1 = var(40)
trigger1 = 1 || var(40) := 0 ;Reset var to prevent looping
value = 0,59
channel = 23
ignorehitpause = 0


[State 0, Electric Shield Gethit]
type = Hitoverride
triggerall = movetype != H
triggerall = stateno != [120,155] ;Not Guarding
trigger1 = Numhelper(2669) ;Is there an electric shield?
stateno = 3107
attr = SCA,NA,NP,SA,SP
time = 1



[State 0, Set H Lightspeed Cancel Bits]
type = Null
triggerall = var(51)
triggerall = var(52) >=200 
triggerall = movecontact
trigger1 = stateno = [1200,1205] ;Homing Attack
trigger1 = 1 || var(42) := var(42) + 512*((var(42)&512)=0)
trigger2 = stateno = 1505 ;M Air Trick
trigger2 = 1 || var(42) := var(42) + 512*((var(42)&512)=0)
trigger3 = stateno = [1100,1104] ;Spindash
trigger3 = 1 || var(42) := var(42) + 1024*((var(42)&1024)=0)
trigger4 = stateno = [2675,2678] ;En Homing Attack
trigger4 = 1 || var(42) := var(42) + 512*((var(42)&512)=0)
ignorehitpause = 1


[State 0, Set L/M Lightspeed Cancel Bits]
type = Null
triggerall = movecontact
triggerall = var(51)
triggerall = var(52) >= 100  
trigger1 = stateno = [1100,1104] ;Spindash
trigger1 = 1 || var(42) := var(42) + 2048*((var(42)&2048)=0)
ignorehitpause = 1


[State 0, Turn off Lightspeed Cancel Bits]
type = Null
trigger1 = stateno != [1200,1205] ;Homing Attack
trigger1 = stateno != [1100,1104] ;Spindash
trigger1 = stateno != 1505 ;M Air Trick
trigger1 = stateno != [1002,1005] ;Lightspeed Dashes
trigger1 = stateno != [2675,2678] ;En Homing Attack
trigger1 = 1 || var(42) := var(42) - (var(42)&512)
trigger1 = 1 || var(42) := var(42) - (var(42)&1024)
trigger1 = 1 || var(42) := var(42) - (var(42)&2048)
ignorehitpause = 1







