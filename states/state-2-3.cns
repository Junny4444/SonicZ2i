persistent = 1
; end of manga palette mode section

;boss options
[State 0, PowerSet]
type = PowerSet
triggerall = (enemy, name = "G. Freeza Z2") || (enemy, name = "Black Z2") || (enemy, name = "Jiren Z2")
triggerall = RoundState = 2
trigger1 = enemy, fvar(39)=1001
trigger2 = enemy,NumProjID(32)
value = 3000
ignorehitpause = 1
;-------------


[State 0, Setup Alt Transformation Mode]
type = Null
triggerall = (var(53)&8) = 0
trigger1 = RoundState = 0
trigger1 = RoundsExisted = 0
trigger1 = command != "holda"
trigger1 = command = "holdb"
trigger1 = command = "holdc"
trigger1 = command = "holdstart"
trigger1 = 1 || var(53) := var(53)+8

;=======================================================
;Advanced EXPLODsive buffer turning
;=======================================================
;disable MUGEN's hardcoded turning
[State -2, AssertSpecial]
type = AssertSpecial
trigger1 = P2DisT x >= -12
flag = noautoturn

[State -2, No walk during turning animation]
type = PosFreeze
triggerall = MoveType != H
trigger1 = anim=5
value = 1
[State 0, AssertSpecial]
type = AssertSpecial
triggerall = MoveType != H
trigger1 = Anim = 5
flag = nowalk

;When to play standing turn anim
[State -2, ChangeAnim]
type = ChangeAnim
triggerall = MoveType != H
triggerall = ctrl
triggerall = Anim !=5
triggerall = StateType !=A
trigger1 = prevstateno !=50
trigger1 = P2DisT x < -12
trigger1 = StateNo = [0,20]
trigger1 = (!AILEVEL && !NumExplod(90000001) && !NumExplod(90000002) && !NumExplod(90000003)) || AILEVEL && command != "holddown"
value = 5
;When to play crouching turn anim
[State -2, ChangeAnim]
type = ChangeAnim
triggerall = MoveType != H
triggerall = StateType !=A
trigger1 = Anim !=6
trigger1 = P2DisT x < -12
trigger1 = ctrl
trigger1 = StateNo = [0,20]
trigger1 = (!AILEVEL && NumExplod(90000001) || NumExplod(90000002) || NumExplod(90000003)) || AILEVEL && command = "holddown"
value = 6

[State 0, ChangeState]
type = ChangeState
triggerall = MoveType != H
triggerall = (!AILEVEL && !NumExplod(90000001) && !NumExplod(90000002) && !NumExplod(90000003)) || AILEVEL && command != "holddown"
triggerall = ctrl
triggerall = Anim !=5
triggerall = P2DisT x < -12
triggerall = StateType !=A
trigger1 = StateNo != [0,20]
trigger1 = MoveType = I
value = 0
ctrl = 1
[State 0, ChangeState]
type = ChangeState
triggerall = MoveType != H
triggerall = (!AILEVEL && NumExplod(90000001) || NumExplod(90000002) || NumExplod(90000003)) || AILEVEL && command = "holddown"
triggerall = ctrl
triggerall = Anim !=6
triggerall = P2DisT x < -12
triggerall = StateType !=A
trigger1 = StateNo != [0,20]
trigger1 = MoveType = I
value = 11
ctrl = 1

;When to actually turn(notice this is below the turn anim code blocks)
[State -2, Turn]
type = Turn
triggerall = P2DisT x < -12
trigger1 = MoveType != H || (StateNo !=[120,155]) 
trigger1 = StateType != A
trigger1 = ctrl
trigger1 = stateno !=52
trigger1 = StateNo = [0,20]
trigger2 = (StateNo = 5120 || StateNo = 8452) && !AnimTime
trigger2 = ctrl=0
[State -2, Turn]
type = Turn
triggerall = FrontEdgeBodyDist <= 2
trigger1 = (StateNo = 5120 || StateNo = 8452) && !AnimTime
trigger1 = ctrl=0

;can throw tech in these states
[State 0, Explod]
type = Explod
triggerall = !NumExplod(98000000)
trigger1 = StateNo = [0,20]
trigger2 = StateNo = [120,152]
trigger3 = StateNo = [800,899]
trigger4 = Stateno = 5120 ;6.0 Fix
anim = 15999
ID = 98000000
removetime = -1
removeongethit = 1
[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = StateNo != [0,20]
trigger1 = StateNo != [120,152]
trigger1 = StateNo != [800,899]
trigger1 = Stateno != 5120 ;6.0 Fix
id = 98000000

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = Var(18) >0
flag = nojugglecheck

[State 0, VarSet]
type = VarSet
trigger1 = P2MoveType != H
var(18) = 0

[State 0, VarSet]
type = VarSet
trigger1 = P2MoveType != H
var(21) = 0

;jump link infinite prevention on tall chars--see state 50 in override
[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = P2MoveType != H
trigger2 = P2StateType = A
trigger3 = StateNo >=1000
id = 52

;this resets the var so he will go to state 5170 correctly in all instances
 [State -2, System Variable Set]
type = VarSet
trigger1 = StateType = S || Statetype = C
sysvar(0) = 0
ignorehitpause = 1

;===============================================================================
; ------- Remove various explods --------
;===============================================================================

[state -2, remove Flip KO FX]
type = removeexplod
trigger1 = anim!=5937
id = 5938
[state -2, remove Twist KO FX]
type = removeexplod
trigger1 = anim!=5052
id = 20152

[state -2, remove charge dust]
type = removeexplod
trigger1 = stateno != 900
trigger1 = stateno != 901
id = 908

[State 0, Air Trick Attack remove FX] ;Air Trick Attack remove FX
type = RemoveExplod
trigger1 = stateno != 1500
trigger1 = stateno != 1505
trigger1 = stateno != 1510
id = 1501

[State 0, Ring Burst/Dash Collision Remove FX]
type = RemoveExplod
trigger1 = stateno != 2405 ;Ring Burst
trigger1 = stateno != 950 ;Dash Collision
trigger1 = stateno != 951 ;Dash Collision Win
trigger1 = stateno != 830 ;Dash Collision Win Attack
id = 2411

[State 0, Remove Ring Burst Ring]
type = RemoveExplod
trigger1 = stateno != 2400 ;Ring Burst Prep
id = 2405


;===============================================================================
; ------- Damage Dampener (Scaling) --------
;===============================================================================
 
[State -2, Counter Flag] 
type = VarSet
trigger1 = NumEnemy
fvar(8) = (EnemyNear, MoveType = A)
ignoreHitPause = 1
 
;Damage Dampener Variable (by POTS)
[State -2, Hit Count] 
type = VarAdd 
trigger1 = !IsHelper
trigger1 = MoveHit = 1 
trigger1 = !HitPauseTime 
trigger1 = !(HitDefAttr = SCA, AT) 
trigger2 = NumProjID(1760)
fvar(13) = 1 
 
[State -2, Hit Count Reset] 
type = VarSet 
trigger1 = NumEnemy && fvar(13) 
trigger1 = (EnemyNear, MoveType != H) && (EnemyNear, StateNo != 5300) 
fvar(13) = 0 
ignoreHitPause = 1
 
[State -2, Dampener] 
type = VarSet 
trigger1 = 1 
fvar(10) = ifElse(fvar(13) < 3, 24, ifElse(fvar(13) >= 23, 1, 24 - fvar(13))) / 24.0 
ignoreHitPause = 1 
 
[State -2, Dampener Limit] 
type = VarSet 
trigger1 = fvar(10) < 0 
fvar(10) = 0 
ignoreHitPause = 1 
 
[State -2, Root Dampener] 
type = VarSet 
trigger1 = 1 
fvar(11) = fvar(10) * ifElse(fvar(8), 1.2, 1) 
ignoreHitPause = 1
;===============================================================================
; ------- Limiters --------
;===============================================================================



[State -2, Air dash reset var when char lands]
type=VarSet
trigger1= statetype!=A
var(10) = 0

[State 0, Reset JP]
type = VarSet
trigger1 = P2MoveType != H
var(18) = 0
[State 0, Reset JP]
type = VarSet
trigger1 = P2MoveType != H
var(35) = 0

[State 0, 5HP hitcount] ;Limiter
type = varset
trigger1 = P2movetype != H
var(12) = 0

[State 0, VarSet] ;Pursuit Limiter Reset
type = varset
trigger1 = P2movetype != H
var(14) = 0

[State 0, VarAdd] ;Homing Attack Limiter Reset
type = varadd
trigger1 = P2movetype != H
var(16) = -(var(16)&15)

[State 0, Ex Air Trick Attack Limiter] ;Ex Air Trick Attack Limiter Reset
type = Null
triggerall = (var(42)&8388608) != 0
trigger1 = P2movetype != H
trigger1 = 1 || var(42) := var(42) - (var(42)&8388608)


[State 0, Air Taunt Limiter Reset] ;Limits Air Taunt in combos
type = Null
trigger1 = p2movetype != H
trigger1 = 1 || var(42) := var(42) - (var(42)&16)
trigger2 = stateno = 111 ;Airdash
trigger2 = 1 || var(42) := var(42) - (var(42)&16)


[State 0, Reset Dropdash Limiter] ;Resets dropdash counter when not in combo
type = Null
triggerall = (var(42)&32) != 0
trigger1 = P2movetype != H
trigger1 = 1 || var(42) := var(42) - (var(42)&32)


[State 0, L Air Trick Limiter] ;Light Air Trick Attack Limiter
type = Null
triggerall = (var(42)&134217728) != 0 ;Limiter ON
trigger1 = Statetype != A
trigger1 = 1 || var(42) := var(42) - (var(42)&134217728)

[State 0, Reset Target Air Status Check] ;For Pursuit Attack
type = Null
triggerall = (var(42)&67108864) != 0 
trigger1 = stateno != [250,251] ;Pursuit Attacks
trigger1 = 1 || var(42) := var(42) - (var(42)&67108864)

[State 0, Reset Air LSA Limiter]
type = Null
triggerall = (var(42)&268435456) != 0 ;Limiter ON
trigger1 = p2movetype != H
trigger1 = 1 || var(42) := var(42) - (var(42)&268435456)


[State 0, En Homing Attack Reset] ;Resets the charge time
type = VarSet
trigger1 = stateno != [2675,2678] ;En Homing Attack
var(39) = 0

[State 0, Reset M Air Trick Limiter]
type = Null
triggerall = (var(42)&8192) != 0 ;Limiter ON
trigger1 = p2movetype != H
trigger1 = 1 || var(42) := var(42) - (var(42)&8192)
trigger2 = stateno = 1510 && movehit ;Ex Air trick attack
trigger2 = (var(42)&8388608) = 0 ;No Limiter Yet
trigger2 = 1 || var(42) := var(42) - (var(42)&8192)


[State 0, Reset Chain Limiters]
type = Null
trigger1 = movetype != A
trigger1 = (var(42)&536870912) != 0 ;5LP
trigger1 = 1 || var(42) := var(42) - (var(42)&536870912)
trigger2 = movetype != A
trigger2 = (var(42)&1073741824) != 0
trigger2 = 1 || var(42) := var(42) - (var(42)&1073741824) ;2LK
ignorehitpause = 1

;Zetto ground recovery redirect
[State 0, TargetState]
type = TargetState
triggerall = NumTarget(755)
triggerall = target(755), Stateno = [5954,5955]
triggerall = target(755),Alive
trigger1 = !(target, ishelper)
trigger1 = target(755),command = "recovery"
value = 799

