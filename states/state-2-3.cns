[State 0, Turn Off Gem PalFX]
type = Null
triggerall = (var(42)&128) = 0 ;PalFX Passthrough
trigger1 = stateno = [1300,1301]
trigger1 = var(42) := var(42) + 128*((var(42)&128)=0)
trigger2 = movetype = H 
trigger2 = var(42) := var(42) + 128*((var(42)&128)=0)





[State 0, Blue Gem PalFX]
type = PalFX
triggerall = (var(42)&128) = 0 ;PalFX Passthrough
trigger1 = var(43) = 1
time = 1
add = 5,5,255
mul = 256,256,256
sinadd = 0,0,2,1
invertall = 0
color = 256
ignorehitpause = 1


[State 0, Green Gem PalFX]
type = PalFX
triggerall = (var(42)&128) = 0 ;PalFX Passthrough
trigger1 = var(43) = 2
time = 1
add = 0,90,70
mul = 256,256,256
sinadd = 0,0,0,1
invertall = 0
color = 256
ignorehitpause = 1

[State 0, Yellow Gem PalFX]
type = PalFX
triggerall = (var(42)&128) = 0 ;PalFX Passthrough
trigger1 = var(43) = 3
time = 1
add = 85,85,0
mul = 256,256,256
sinadd = 0,0,0,1
invertall = 0
color = 256
ignorehitpause = 1

[State 0, White Gem PalFX]
type = PalFX
triggerall = (var(42)&128) = 0 ;PalFX Passthrough
trigger1 = var(43) = 4
time = 1
add = 80,80,80
mul = 256,256,256
sinadd = 0,0,0,1
invertall = 0
color = 256
ignorehitpause = 1


[State 0, Electric Shield]
type = Helper
triggerall = (var(42)&256) != 0
trigger1 = !NumHelper(2669)
stateno = 2669
ID = 2669
pos = 0,0
name = "Electric Shield"
postype = P1  ;P2, Front, Back, Left, Right
ownpal = 1
ignorehitpause = 0

[State 0, Install Meter Penalty Countdown]
type = VarAdd
triggerall = gametime%2 = 0
trigger1 = var(49)
var(49) = -1

;===============================================================================
; ------- Death System --------
;===============================================================================

[State 0, Dead Drop Rings]
type = Helper
triggerall = TeamMode != Simul
triggerall = enemyNear,TeamMode != Simul
triggerall = !alive
triggerall = matchover
triggerall = stateno = [5000,5100]
trigger1 = Numhelper(2672) < 25
trigger1 = (var(42)&33554432) = 0
name = "Dead Rings"
ID = 2672
stateno = 2672
pos = 0,0
postype = P1


[State 0, Reset Dropped Rings Bit if Alive]
type = Null
triggerall = alive
trigger1 = 1 ||  var(42) := var(42) - (var(42)&33554432)



;---------------------------------------------------------------
;Slashing Chop
[State -2, Focus Attack meter reset when no longer charging]
type = VarSet
trigger1 = (StateNo !=[1300,1301]) && ((StateNo = [5000,5099]) && PrevStateNo != 1300)
trigger2 = StateNo = [100,105]
fv = 9
value = 0

[State -2, Reset var when the opponent recovers]
type=VarSet
trigger1= NumEnemy
trigger1= (enemynear,movetype!=H)
trigger2= !NumEnemy
var(7) = 0
ignorehitpause = 1

[State -2, OTG]
type= VarSet
trigger1= MoveContact=1 && p2statetype!=L
var(6) = 0
ignorehitpause = 1
[State -2, Free Juggling] ;NO JUGGLE CHECK nojugglecheck free juggling
type = assertspecial
trigger1 = var(6)=1
flag = nojugglecheck
ignorehitpause = 1

[State -2, Super Jump reset var when char lands]
type=VarSet
trigger1= statetype!=A
var(22) = 0

[State -2, KO snd]
type = VarSet
trigger1 = alive && var(8) > 0
trigger2 = !alive && var(8) < 2
var(8) = IfElse(alive, 0, var(8) + 1)
ignorehitpause = 1

;These controllers play the "hit ground" sound effect everytime the enemy hits the ground, 
;during different custom states.
[State -2, Hitting ground sound effect];Strong sound effect, first bounce.
type		= PlaySnd
triggerall	= NumTarget		;You must have a target
triggerall	= Target, Time = 1
trigger1		= Target, StateNo = 652	;custom state: a.SP
trigger2 = Target, Stateno = 654 ;custom state: a.214HK
trigger3 = Target,stateno = 2212005 ;Custom State: Sonic Wind Level 2
value		= 15000, 2
ignorehitpause	= 1
channel		= 20
[State -2, Hitting ground sound effect];Medium sound effect, first bounce
type		= PlaySnd
triggerall	= NumTarget
triggerall	= Target, Time = 1
trigger1		= Target, StateNo = 1115100	;custom state: Dizzy/Stun, falling
value		= 15000, 1
ignorehitpause	= 1
channel		= 21
[State -2, Hitting ground sound effect];Weak sound effect, second bounce
type		= PlaySnd
triggerall	= NumTarget
triggerall	= Target, Time = 1
trigger1		= Target, StateNo = 1115110	;custom state: Dizzy/Stun, falling
value		= 15000, 0
ignorehitpause	= 1
channel		= 22

