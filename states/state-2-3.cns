triggerAll = NumHelper(90000005) && !IsHelper && !AILevel && NumEnemy
trigger1 = Helper(90000005), command = "fwd" && Helper(90000005), command != "back" && Helper(90000005), command != "up" && Helper(90000005), command != "down"
anim = 1
ID = 90001026
