[State 0, DisplayToClipboard]
type = DisplayToClipboard
trigger1 = 1
text = "var(2) = %d, var(49)= %d, Vel X = %f, Juggle Points = %d, 50 = %d"
params = var(2),var(49),screenpos x,var(18),(var(53)&32)
ignorehitpause = 1

[State -2, Training stuff, it won't effect the gameplay]
;also I'm tired of pressing the spacebar. :P
type = AssertSpecial
trigger1 = Enemy, Name = "Training"
flag = timerfreeze
ignorehitpause = 1

[State -2, EXPLODsive Buffering Helper]
type = Helper
trigger1 = !NumHelper(90000005)
stateNo = 90000005
ID = 90000005
name = "EXPLODsive Buffering helper"
posType = P1
facing = ifElse(Facing = 1, 1, -1)
keyCtrl = 1
ignoreHitPause = 1


[State -2, Please Live]
type = AssertSpecial
triggerall = numenemy < 2 && numpartner < 2
triggerall = Enemy,life != 0
trigger1 = (var(42)&256) != 0 || stateno = 3107
flag = NoKO


;manga palette mode section
[State 0, RemapPal]
type = RemapPal
triggerall = var(58) 
triggerall = RoundState = 0
triggerall = RoundsExisted = 0
triggerall = PalNo = 1
trigger1 = !AILEVEL
trigger1 = command = "holda"
trigger1 = command = "holdb"
trigger1 = command = "holdstart"
trigger2 = AILEVEL
trigger2 = enemy, authorname = "Team Z2"
trigger2 = enemy, NumProjID(59098)
source = 1,1
dest = 1,5900

[State 0, varset]
type = varset    
triggerall = var(58) 
triggerall = RoundState = 0
triggerall = RoundsExisted = 0
triggerall = PalNo = 1
trigger1 = !AILEVEL
trigger1 = command = "holda"
trigger1 = command = "holdb"
trigger1 = command = "holdstart"
trigger2 = AILEVEL
trigger2 = enemy, authorname = "Team Z2"
trigger2 = enemy, NumProjID(59098)
var(58) = 5900

[State 0, RemapPal]
