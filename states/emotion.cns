
;HIGHSPEED ACTIVATE
[Statedef 2600]
type = S
movetype = I
physics = S
anim = 2600 
ctrl = 0
velset = 0,0
sprpriority = 2
poweradd = -2000

[State 4500, Start Sound]
type = PlaySnd
trigger1 = animelemtime(2) = 0
value = 2350,2

[State 4500, Peel Loop]
type = PlaySnd
trigger1 = animelemtime(20) < 0
trigger1 = time%10 = 0
value = 100,2
channel = 1

[State 4500, Peel Release]
type = PlaySnd
trigger1 = animelemtime(20) = 0
value = 100,4
channel = 1

[State 4500, Charge Dust]
type = Explod
trigger1 = animelemtime(20) < 0
trigger1 = time%12 = 0
anim = 1206
ID = 1206
pos = 0,0
postype = p1
bindtime = 1
sprpriority = -1
vel = -1,0
random = 5,2
removetime = -2
supermovetime = 999

[State 4500, Dash SND]
type = PlaySnd
trigger1 = animelemtime(20) = 0
trigger2 = animelemtime(23) = 0
trigger3 = animelemtime(26) = 0
value = 186,2
channel = 2

[State 4500, Dash Shake]
type = EnvShake
trigger1 = animelemtime(20) = 0
trigger2 = animelemtime(23) = 0
trigger3 = animelemtime(26) = 0
time = 6
ampl = -4

[State 0, Turn Emo On]
type = VarSet
trigger1 = Time <= 0
trigger1 = 1 || var(52) := 0 ;Set Meter (Normal Values)
;trigger1 = 1 || var(52) := 600 ;Set Meter (Debug Values)
var(51) = 1
ignorehitpause = 1

[State 200, BGPalFX]
type = BGPalFX
trigger1 = animelemtime(2)=0
time = -animtime
add	= -100,-100,-100
mul	= 100,100,256
invertall = 0
color = 256




[State 3000, superpause]
type = superpause
trigger1 = animelemtime(2) = 0
time = -animtime
p2defmul = 1
unhittable = 1
anim = -1
darken = 0
movetime = -animtime

[State 195, 2]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1
