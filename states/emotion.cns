add = 128,128,128
sinadd = -128,-128,-128,32
time = 8


[State 0, PlaySnd]
type = PlaySnd
trigger1 = 1
value = S2000,15
persistent = 0



[State 0, ReversalDef]
type = ReversalDef
triggerall = abs(Pos x - enemynear, Pos x) <= 160
trigger1 = time < 40
reversal.attr = SCA,AA        ;SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
pausetime = 0,0
p1stateno = 2350
sparkno = -1
hitsound = -1


[State 0, NotHitby]
type = Nothitby
trigger1 = time < 40
value = SCA,AA      
time = 1

[State 0, HitBy]
type = HitBy
trigger1 = time < 40
value = SCA,AP,AT
time = 1

[State 0, Go To Attack In Combo]
type = ChangeState
trigger1 = (var(42)&67108864) != 0
trigger1 = var(42) := var(42) - (var(42)&67108864)
value = 2350
ctrl = 0


[State 0, ChangeState]
type = ChangeState
trigger1 = !animtime
value = 0
ctrl = 1


