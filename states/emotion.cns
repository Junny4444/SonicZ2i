guard.velocity = -9
airguard.velocity = -2.5,-1.3
air.type = High	
air.velocity = -4,-4
air.hittime = 12
air.animtype = back
getpower= 0,0
givepower = 35,35
yaccel = 0.5
fall = 0
kill = 0
p2facing = 1
envshake.time = 40
envshake.ampl = 5
envshake.freq = 75
fall.envshake.ampl = ID
