[State 0, Turn Off 214HK Bit]
type = Null
triggerall = time <= 0
trigger1 = ((ifElse(P2DisT x < -12, Facing = -1, Facing = 1) && NumExplod(90010006)) || (ifElse(P2DisT x < -12, Facing = 1, Facing = -1) && NumExplod(90010104)))
trigger1 = 1 || var(42) := var(42) - (var(42)&16777216)
trigger2 = time <= 0
trigger2 = prevstateno = 1004
trigger2 = 1 || var(42) := var(42) - (var(42)&16777216)
persistent = 0


[State 0, Set for 214HK]
type = Null
triggerall = var(2) >=300 && var(51) = 0 || var(2) >=150 && var(51) = 1
triggerall = time <= 0
trigger1 = ((ifElse(P2DisT x < -12, Facing = -1, Facing = 1) && NumExplod(90010104)) || (ifElse(P2DisT x < -12, Facing = 1, Facing = -1) && NumExplod(90010006)))
trigger1 = 1 || var(42) := var(42) + 16777216*((var(42)&16777216)=0)
persistent = 0



