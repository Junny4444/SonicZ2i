[State 0, Hitdef]
type = HitDef
trigger1 = animelem = 6
attr = S, HA
damage = ceil(ifElse(fvar(11) * 23 < 7, 7, fvar(11) * 23)), 0
animtype = Hard	
guardflag = MA
priority = 4,Hit
hitflag = MAF
pausetime = 0,15
guard.pausetime = 11,11
sparkno = s7030
guard.sparkno = s7000
sparkxy = -19,-30
hitsound = s5, 2
guardsound = S6,0
ground.type = High
air.type = Low
