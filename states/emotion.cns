ctrl = 0








;Electric Shield Hit State
[Statedef 3107]
Type = U
movetype = H
Physics = N
ctrl = 0
anim = 3107

[State 0, Debug]
type = Null
trigger1 = 1
text = "dmg = %d, time = %d, store = %d"
params = gethitvar(damage), time, fvar(2)
ignorehitpause = 1

[State 0, Get Damage]
type = Null
trigger1 = time <= 0 
trigger1 = 1 || fvar(2) := ceil(gethitvar(damage))
ignorehitpause = 1
persistent = 0


[State 0, Remove Emo]
type = VarAdd
trigger1 = 1
var(52) = 20
persistent = 0

[State -3, GetHitSnd Medium]
type = PlaySnd
trigger1 = alive 
value = s5000,10+random%3
channel = 0
ignorehitpause = 1
persistent = 0
volumescale = 200


[State 0, Keep Health]
type = Lifeadd
trigger1 = time >= 1
value = fvar(2)
ignorehitpause = 1
persistent = 0

[State 0, Remove Electric Shield]
type = Null
triggerall = time >= cond(gethitvar(hittime) <= 3,0,3)
trigger1 = 1 || var(42) := var(42) - (var(42)&256)
persistent = 0

[State 0, Invul]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1


[State 0, StateTypeSet]
type = StateTypeSet
trigger1 = pos y < 0
statetype = A     
ignorehitpause = 1
persistent = 1

[State 0, StateTypeSet]
type = StateTypeSet
trigger1 = pos y >= 0
statetype = S     
ignorehitpause = 1
persistent = 1


[State 0, VelSet]
type = VelSet
trigger1 = 1
x = gethitvar(xvel)*facing
y = gethitvar(yvel)
persistent = 0



[State 0, Gravity]
type = veladd
trigger1 = 1
y = gethitvar(yaccel)
persistent = 0


[State 0, PosSet]
type = PosSet
trigger1 = pos y >= 0
y = 0




[State 0, end]
type = ChangeState
trigger1 = Time >= gethitvar(hittime)
value = cond(pos y>= 0,0,50)
ctrl = 1


