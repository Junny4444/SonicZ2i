pos = 0,10
postype = P1
sprpriority = 3
ownpal = 1
removetime = -2
persistent = 0
ignorehitpause = 1
scale = .8,.8


[State 0, ChangeState]
type = ChangeState
trigger1 = !Animtime
value = 1610
ctrl = 0

;Projectile Rebound State 
[StateDef 1610]   
type = A          
movetype = I      
physics = A       
anim = 1602         
ctrl = 0

[State 0, CtrlSet]
type = CtrlSet
trigger1 = Time = 15
value = 1


[State 0, VelAdd]
type = VelAdd
triggerall = prevstateno = 2000 ;For Sonic Wind Super
trigger1 = Time = 0
x = -1
y = -10
ignorehitpause = 1


[State 0, VelAdd]
type = VelAdd
triggerall = prevstateno = 1605 ;For Sonic Wave
trigger1 = Time = 0
x = -3
y = -10
ignorehitpause = 1





;-----------------------------------------
; Light Speed Dash Custom Fall State
[Statedef 16000]
type = A
movetype = H
physics = N
anim = IfElse(selfanimexist(5937),5937,IfElse(selfanimexist(5052),5052,5030))
ctrl = 0
facep2 = 1

[State 0, NotHitBy]
type = null;NotHitBy
trigger1 = enemy,NumExplod(1400)>1
value = SCA
time = 1

[state 3052] ;pos set if too close to the ground
type = posadd
trigger1 = !time && pos y >= -10
y = -10
persistent = 0

[State 4005, vel]
type = velset
trigger1 = AnimElemtime(2)=0
x = -0.5
y = -10
persistent = 0

[State 9011, VelAdd]
type = VelAdd
trigger1 = Pos Y < 0
y = 0.35
 
[State 9011, ChangeState]
type = SelfState
trigger1 = (Pos Y >= 0) && (Vel Y > 0)
value = 5100


;-----------------------------------------
; Falling from Light Speed Dash
[Statedef 16005]
type    = A
physics = A

[State 50, 2]
type = ChangeAnim
trigger1 = Time = 0
value = 16005

;-----------------------------------------------
; P2 Hit by EX Air Trick Attack (custom state)
[Statedef 3124]
type = A
movetype = H
physics = N ;A
ctrl = 0
velset = 0,0
poweradd = 0
sprpriority = 2
facep2=1

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = noautoturn
ignorehitpause = 1
;persistent =


[State 0, Turn]
type = Turn
trigger1 = !time
ignorehitpause = 1
;persistent =



[State 3124, ChangeAnim]
type = ChangeAnim
trigger1 = !time && SelfAnimExist(5052)
value = 5052

[State 3124, ChangeAnim2]
type = ChangeAnim2
trigger1 = !time && !SelfAnimExist(5052)
value = 3103


[State 3124, VelAdd]
type = VelSet
trigger1 = !Time ;(Pos Y < 0)
x = cond(Facing,13,-13) ;10
y = -8;-5

[State 0, Gravity]
type = Gravity
trigger1 = 1

[State 3124, No scroll]
type = ScreenBound
triggerall = Pos y < -15
trigger1 = BackEdgeBodyDist < 65
trigger2 = FrontEdgeBodyDist < 65
value = 1
movecamera = 0,1

[State 3103, Hit wall]
type = ChangeState
triggerall = alive
triggerall = Pos y < -15
trigger1 = BackEdgeBodyDist <= 20
trigger2 = FrontEdgeBodyDist <= 20
value = 3104

[State 1323, Wallbounce ko] 
type = ChangeState
triggerall = !alive
triggerall = Pos y < -15
trigger1 = BackEdgeBodyDist <= 20
trigger2 = FrontEdgeBodyDist <= 20
value = 1323

[State 3124, ChangeState]
type = SelfState
trigger1 = (Pos Y >= 0) && (Vel Y > 0)
value = 5100

