;SPEED DASH BACKDASH (214LK)
[StateDef 1000]   
type = S         
movetype = I      
physics = S       
anim = 1000             
ctrl = 0           

[State 0, VelAdd] ;Go backwards
type = VelAdd
trigger1 = AnimElem = 4
x = -13

[state 1215, Smoke FX]
type = explod
trigger1 = AnimElem = 4
anim = 1209
id = 1206
pos = 10,0
postype = P1
sprpriority = 3
ownpal = 1
removetime = -2
persistent = 0
ignorehitpause = 1
scale = .8,.8


[State 0, PlaySnd]
type = PlaySnd
trigger1 = AnimElem = 2
value = S0,52
volume = 1
channel = -1



[State 0, VelAdd]
type = VelAdd
trigger1 = AnimElem = 5
x = -3


[State 0, Velmul]
type = VelAdd
trigger1 = AnimElem = 7
x = 1

[State 100, snd]
type = playsnd
trigger1 = AnimElem = 7
value = 5,8
persistent = 0


[State 0, ChangeState]
type = ChangeState
trigger1 = !AnimTime
value = 0
ctrl = 1

      



