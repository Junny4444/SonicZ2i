;-------------------------------------
;Wall Hit by EX Air Trick Attack (custom state)
[Statedef 3104]
type    = A
movetype= H
physics = N
ctrl = 0
velset = 0,0
poweradd = 0
sprpriority = 3

[State 3104, ChangeAnim2]
type = ChangeAnim2
trigger1 = !time
value = 3104

[State 3104, VelAdd]
type = VelSet
trigger1 = !Time 
x = -10
y = -5

[State 3104, ChangeState]
type = SelfState
trigger1 = (Pos Y >= 0) && (Vel Y > 0)
value = 5100

[State 3104, Turn]
type = Turn
trigger1 = (Time = 0) && (FrontEdgeBodyDist <= 30)

[State 3104, Pos]
type = PosAdd
trigger1 = Time = 0
x = 15 - BackEdgeBodyDist

[State 3104, Stop moving]
type = PosFreeze
trigger1 = 1
x = 1
y = 1

[State 3104, No scroll]
type = ScreenBound
trigger1 = 1
value = 1
movecamera = 0,1

[State 3104, State]
type = ChangeState
trigger1 = AnimTime = 0
trigger2 = time>8
value = 3105

;-------------------------------------
;Wall Bounce by EX Air Trick Attack (custom state)
[Statedef 3105]
type    = A
movetype= H
physics = N
facep2 = 1
sprpriority = 2

[State 3105, Vel]
type = VelSet
trigger1 = Time = 0
x = 1.6
y = -6

[State 3105, Gravity]
type = VelAdd
trigger1 = 1
y = .35

[State 3105, Anim 5050] 
type = ChangeAnim
trigger1 = Time = 0
trigger1 = !SelfAnimExist(5052)
value = 5050

[State 3105, Anim 5052] ;Self falling animation (diagup type)
type = ChangeAnim
trigger1 = Time = 0
trigger1 = SelfAnimExist(5052)
value = 5052

[State 3105, Anim 5060] ;Coming down - normal
type = ChangeAnim
trigger1 = Vel Y > -2
trigger1 = Anim = 5050
trigger1 = SelfAnimExist(5060)
persistent = 0
value = 5060

[State 3105, Anim 5062] ;Coming down - diagup type
type = ChangeAnim
trigger1 = Vel Y > -2
trigger1 = Anim = 5052
trigger1 = SelfAnimExist(5062)
persistent = 0
value = 5062

[State 3105, Hit ground]
type = SelfState
trigger1 = (Vel y > 0) && (Pos y >= 0)
value = 5100




