[StateDef 1001]   
type = S         
movetype = I      
physics = S       
anim = 1001             
ctrl = 0           

[State 0, VelAdd] ;Go Forwards
type = VelAdd
trigger1 = AnimElem = 4
x = 15

[state 1215, Smoke FX]
type = explod
trigger1 = AnimElem = 4
anim = 1206
id = 1206
pos = 10,0
postype = P1
sprpriority = 3
ownpal = 1
removetime = -2
persistent = 0
ignorehitpause = 1
scale = .8,.8


[State 0, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 0


[State 0, PlaySnd]
type = PlaySnd
trigger1 = AnimElem = 2
value = S0,52
volume = 1
channel = -1



[State 0, Width]
type = Width
trigger1 = AnimElemtime(4) >= 0
edge = -23,-23
persistent = 1


[State 0, VelAdd]
type = VelAdd
trigger1 = AnimElem = 5
x = 3


[State 0, Velmul]
type = VelAdd
trigger1 = AnimElem = 7
x = -1

[State 100, snd]
type = playsnd
trigger1 = AnimElem = 7
value = 5,8
persistent = 0


[State 0, ChangeState]
type = ChangeState
trigger1 = !AnimTime
value = 0
ctrl = 1


;----------------------------
;SpinDash (236P)
[StateDef 1100]
type = S
movetype= A
physics = S
velset = 0,0
ctrl = 0
anim = 1100
poweradd = 25
sprpriority = 2

[State 0, Spindash Hitcount] ;Resets the limiter
type = VarSet
trigger1 = 1
var(11) = 0
persistent = 0


[State 0, Width]
type = Width
trigger1 = 1
value = 15,6
ignorehitpause = 1



[state 1215, Smoke FX]
type = explod
trigger1 = AnimElem = 3
anim = 1206
id = 1206
pos = -10,0
postype = P1
sprpriority = 3
ownpal = 1
removetime = -2
persistent = 0
ignorehitpause = 1
scale = .8,.8


[State 1400, 1]
type = HitDef
triggerall = Var(18) <= 15
trigger1 = AnimElem = 3
trigger2 = AnimElem = 4
trigger3 = AnimElem = 5
trigger4 = AnimElem = 6
attr = S, SA
damage = ceil(ifElse(fvar(11) * 14 < 7, 7, fvar(11) * 14)), 5
animtype = hard
guardflag = LA
hitflag = MAF
priority = 3, Hit
pausetime = 8, 8
guard.pausetime = 6,6
sparkno = s7020
guard.sparkno = s7000
sparkxy = -10, -26
hitsound = s5, 2
guardsound = s6, 0
ground.type = low
ground.slidetime = 24
ground.hittime  = 24
guard.hittime = 5
ground.velocity = -6
airguard.velocity = -1.9,-.8
air.type = High
air.velocity = -1.4,-3
air.hittime = 128
getpower = ifelse(p2movetype = H,75,175),35
envshake.time = 10
down.hittime = 30
envshake.ampl = 3

[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 4
value = S100,2


[State 1400, end]
type = Changestate
trigger1 = time = 23
value = 1101
ctrl = 0
;----------------------


;SpinDash Part 2
[StateDef 1101]
type = S
movetype= A
physics = N
;velset = 0,0
ctrl = 0
anim = 1101
poweradd = 0
sprpriority = 2


[State 0, Reset Bits]
type = Null
trigger1 = 1 || var(42) := var(42) - (var(42)&4194304)
persistent = 0


[State 0, Set Hit Bit]
type = Null
triggerall = movecontact
trigger1 = 1 || var(42) := var(42) + 4194304*((var(42)&4194304)=0)
persistent = 0



[State 0, Width]
