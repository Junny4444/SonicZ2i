guard.hittime = 18
guard.ctrltime = 12
airguard.velocity = -3.5,-4
air.type = High
air.velocity = -3.5,-6
air.hittime = 9
getpower = 101,101
givepower = 35,35
envshake.time = 7
envshake.ampl = 3
envshake.freq = 40
ground.cornerpush.veloff = -7.25
air.cornerpush.veloff = 0
yaccel = .55
fall.envshake.ampl = ID
