;LIGHTSPEED CHARGE
;===========================================================================
[StateDef 900]
type = S
movetype = I
physics = S
anim = 900
velset = 0,0
ctrl = 0

[State 900, Add to LSD] ;Add to Light speed dash meter
type = VarAdd
triggerall = (Anim = 900)
triggerall = Time >= 12
trigger1 = (AILevel<=0) && (command = "holdb") && (command = "holdy")
trigger2 = AILevel>0
v = 2
value = 1 + ((time-250)/480)

[State 900, Add to LSD] ;Add to Light speed dash meter
type = VarAdd
triggerall = (Anim = 900)
triggerall = Time >= 60
trigger1 = (AILevel<=0) && (command = "holdb") && (command = "holdy")
trigger2 = AILevel>0
v = 2
value = 2 + ((time-800)/440)


[State 4500, 2];long sound
type = PlaySnd
trigger1 = time=1
value = 8,0
loop = 1
pan = 1
volumescale = 100
channel = 3

[State 4500, 1];Scream
type = PlaySnd		
trigger1 = animelemtime(4)=0
value = 8,1
volumescale = 255
channel = 4

