ignorehitpause	= 1

[State 750, Punches or Kicks?]
type		= VarSet
triggerall          = p2statetype != A
trigger1		= !Time && AILevel>0
trigger1            = (p2bodydist x=[61,120])
var(17)		= 1
ignorehitpause	= 1
[State 750, Punches or Kicks?]
