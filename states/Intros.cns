;---------------------------------------------------------------------------
; INTRO 1 , Sleeping
[Statedef 700] 
type = S
ctrl = 0
anim = 700
velset = 0,0

[State 182, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1

[State 700, 1] ;Freeze animation until PreIntro is over
type = ChangeAnim
trigger1 = RoundState = 0
value = 700

[State 700, 2] ;Assert this until you want "round 1, fight" to begin
type = AssertSpecial
trigger1 = 1
flag = Intro

[State 17100, Intro Speech]
type = PlaySnd
trigger1 = AnimElemTime(2)=0
value = 190,0
channel = 0
volumescale = 200

[State 700, 4] ;Change to stand state
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 0
;---------------------------------------------------------------------------
; INTRO 2, Sonic Battle Summon
[Statedef 701] 
type = S
ctrl = 0
anim = 701
velset = 0,0

[State 182, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1

[State 700, 1] ;Freeze animation until PreIntro is over
type = ChangeAnim
trigger1 = RoundState = 0
value = 701

[State 700, 2] ;Assert this until you want "round 1, fight" to begin
type = AssertSpecial
trigger1 = 1
flag = Intro

[State 17100, "Time to party!"]
type = Null
trigger1 = AnimElemTime(2)=0
value = 190,0
channel = 0
volumescale = 200

[State 700, 4] ;Change to stand state
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 0