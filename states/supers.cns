trigger1 = time >= 20
trigger1 = !Numhelper(220000)
stateno = 220000
ID = 220000
postype = P1
pos = floor(abs(pos x - target,pos x)),floor(abs(pos y - target,pos y))
persistent = 0
ownpal = 1
persistent = 0


[State 0, EnvShake]
