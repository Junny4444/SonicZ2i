;ScreenBound Helper
[Statedef 2213]
type = A
physics = N
anim = 1

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 1
movecamera = 1,1



[State 0, Init]
type = Null
trigger1 = 1 || var(2) := Ishelper(2214) 
trigger1 = 1 || var(0) := root,id || var(1) := parent,id
persistent = 0


[State 0, Left Bound]
type = PosAdd
trigger1 = !var(2)
x = -screenpos X
y = floor(-screenpos Y + gameheight)
ignorehitpause = 1

[State 0, Right Bound]
type = PosAdd
trigger1 = var(2)
x = floor(-screenpos X + gamewidth)
y = floor(-screenpos Y + gameheight)
ignorehitpause = 1


[State 0, DestroySelf]
