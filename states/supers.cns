movetype = I      ; AIHU
physics = N       ; SCANU
anim = 41          ;refers to the .Air file
velset = 2.5,-5      
ctrl =  0        


[State 0, ChangeState]
type = ChangeState
trigger1 = Time >= 5
value = 2000
ctrl = 0
ignorehitpause = 1

;Loop Kick Start (j.236236K)
[StateDef 2100]   
type = A          ; SCA
movetype = A      ; AIHU
physics = N       ; SCANU
anim = 2100          ;refers to the .Air file
velset = 0,0     
ctrl =  0     


[State 0, Reset Hit Bit]
type = Null
triggerall = (var(42)&32768) != 0
trigger1 = 1 || var(42) := var(42) - (var(42)&32768)
persistent = 0

[State 0, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 0

[State 0, PosAdd]
type = PosAdd
trigger1 = pos y >= -10
y = -15
persistent = 0

[State 0, VelSet]
type = VelSet
trigger1 = animelemtime(3) < 0 
x = 1
persistent = 0


[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 3
value = S100,2
persistent = 0




[State 0, VelSet]
type = VelSet
triggerall = animelemtime(3) >= 0 
trigger1 = Time < 45
x=10.5*sin(time*0.15)
y=2.5*cos(time*0.15)

[State 0, VelSet]
type = VelSet
triggerall = animelemtime(3) >= 0 
trigger1 = Time > 45
x=16.5*sin(time*0.15)
y=2.5*cos(time*0.15)

[State 0, ChangeState]
type = changestate
trigger1 = Time > 50
value = 2105
ctrl = 0

;Loop Kick Lock on
[StateDef 2105]   
type = A          ; SCA
movetype = A      ; AIHU
physics = N       ; SCANU
anim = 2101          ;refers to the .Air file
velset = 0,0     
ctrl =  0    
poweradd = -1000  
facep2 = 1

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = time >= 1
flag = noautoturn

[State 282, end]
type = changestate
trigger1 = pos y>=0 
value = 52


[State 0, Voice]
type = PlaySnd
trigger1 = !time
value = S2000,2+random%5
channel = 0

[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 2
value = S0,58
channel = 1
    
[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = animelemtime(1) >= 0 && animelemtime(2) < 0
flag = noBG
flag2 = noFG

[State 3000, superpause]
type = superpause
trigger1 = 1
time = 40
p2defmul = 1
unhittable = 1
anim = -1
sound = s2000,0
darken = 0
movetime = 40
persistent = 0

[State 0, Super FX]
type = Explod
trigger1 = Time = 0
anim = 2003
id = 2003
pos = 0,-30    ;-145,52
postype = p1
supermovetime = 9999
pausemovetime = 9999
supermove = 1
removetime = -2
sprpriority = 8
ownpal = 1
bindtime = 1
scale = 1,1
persistent = 0


[State 24010, Conditional Varset]
type = null
trigger1 = numenemy
trigger1 = 1 || (fvar(4):= enemynear,pos x - pos x) * facing 
trigger1 = 1 || (fvar(5):= enemynear,pos y -20 - pos y)
trigger1 = 1 || (fvar(6):=((fvar(4)**2.0)+(fvar(5)**2.0))**0.5) 


[State 24010, Velset]
type = velset
trigger1 = animelem = 2
x = 14.0*cond(fvar(4)/fvar(6) != 0,fvar(4)/fvar(6),1)*facing
y = 14.0*cond(fvar(5)/fvar(6) != 0,fvar(5)/fvar(6),1)
ignorehitpause = 1

[State 200, 1]
type = Hitdef
trigger1 = !movecontact
attr = S, NA
damage = ceil(ifElse(fvar(11) * 130 < 85, 85, fvar(11) * 130)), 10
animtype = Hard	
guardflag = MA
priority = 4,Hit
hitflag = MAF
pausetime = 36,36
guard.pausetime = 24,24
sparkno = s7030
guard.sparkno = s7000
sparkxy = -19,-30
hitsound = s5, 2
guardsound = S6,0
ground.type = High
air.type = Low
ground.slidetime = 28
ground.hittime  = 28
guard.hittime  = 23
ground.velocity = -7,-4
guard.velocity = -9
airguard.velocity = -2.5,-1.3
air.type = High	
air.velocity = -7,-4
fall = 1
air.fall = 1
fall.recover = 0
air.animtype = back
getpower= 0, 0
givepower = 35,35
yaccel = 0.5
envshake.time = 15
envshake.ampl = 4
envshake.freq = 40
persistent = 0
ID = 2105

;Lightspeed Dash Meter gain values
[State 0, Add to Bar]
type = VarSet
trigger1 = Movehit = 1
var(2) = cond(var(2) <= 150,var(2) + 150,300)
ignorehitpause = 1
persistent = 0



[State 0, VarAdd] ;Install meter gain
type = VarAdd
triggerall = var(51) = 1
trigger1 = movehit = 1 && var(52) <= cond(!var(49),435,555)
var(52) = cond(!var(49),165,45)
ignorehitpause = 1
persistent = 0


[State 0, VarSet] ;Install meter gain 
type = VarSet
triggerall = var(51) = 1
trigger1 = movehit = 1 && var(52) > cond(!var(49),435,555)
var(52) = 600
ignorehitpause = 1
persistent = 0

[State 282, hit]
type = changestate
trigger1 = Movecontact
value = 2110


[State 0, Set Hit Bit]
type = Null
triggerall = (var(42)&32768) = 0
trigger1 = movehit
trigger1 = 1 || var(42) := var(42) + 32768*((var(42)&32768)=0)
persistent = 0
ignorehitpause = 1


[State 0, Fail]
type = ChangeState
trigger1 = Pos Y < -700
trigger2 = Time > 70
trigger3 = abs(pos x - enemynear, pos x) <= 10
value = 50
ctrl = 1



