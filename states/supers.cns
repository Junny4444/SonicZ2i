;Sonic Wind Level 1 Air (j.236236P)
[StateDef 2000]   
type = A         
movetype = A      
physics = N       
anim = 2000          
ctrl = 0 
velset = 0,0   
poweradd = -1000 

[State 0, AfterImage]
type = AfterImage
trigger1 = animelem = 4
time = 130
TimeGap  = 2
FrameGap = 3
length = 10
PalBright = 1,1,1
PalContrast = 1, 10, 150
PalAdd = 0,0,0
PalMul = .5,.5,.5
trans = add1 

[State 0, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 0



[State 0, Reset Vars]
type = Null
trigger1 = 1 || var(42) := var(42) - (var(42)&2)
trigger1 = 1 || var(42) := var(42) - (var(42)&2097152)
persistent = 0    


[State 9000, 1];ŽžŒv‰ñ‚è
type = velset
trigger1 = animelemtime(4) >= 0
x = 25*cos(time*0.5+pi)
y = 4*sin(time*0.5+pi)


[State 0, PlaySnd]
type = PlaySnd
trigger1 = Time = 2
value = S2000,1+random%6
volumescale = 100
channel = 0
freqmul = 1.0
loop = 0
pan = 0

[State init]
type = null
trigger1 = 1 || var(9) := -6
persistent = 0

[State layer]
type = sprpriority
triggerall = animelemtime(5) >= 0
trigger1 = time%8 = 0
trigger1 = var(9) := cond(var(9) = -6,9,-6)
value = var(9)

[State 3000, superpause]
type = superpause
trigger1 = AnimElem = 3
time = 40
p2defmul = 1
unhittable = 1
anim = -1
sound = s2000,0
darken = 0
movetime = 40

[State 0, NotHitBy]
type = NotHitBy
triggerall = (var(42)&2) = 0 ;Checks if Invuln Bit turned off
trigger1 = AnimElemtime(13) < 0
value = SCA
time = 1

[State 0, Turn Off Invuln]
type = Null
trigger1 = AnimElemtime(13) >= 0
trigger1 = 1 || var(42) := var(42) + 2*((var(42)&2)=0)
persistent = 0


[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = animelemtime(3) >= 0 && animelemtime(4) < 0
flag = noBG
flag2 = noFG

[State 0, Super FX]
type = Explod
trigger1 = AnimElem = 3
anim = 2003
id = 2003
pos = 0,-45    ;-145,52
postype = p1
supermovetime = 9999
pausemovetime = 9999
supermove = 1
removetime = -2
sprpriority = 8
ownpal = 1
bindtime = 1
scale = 1,1
persistent = 0

[State 1000, Sonic Wind]
type = Helper
triggerall = !Numhelper(1800)
trigger1 = AnimElem = 4
name = "SonicWind"
postype = P1
pos = 0,0
ownpal = 1
size.xscale = 1
size.yscale = 1
stateno = 1800
id = 1800
persistent = 0


[State 0, VelSet]
type = VelSet
trigger1 = time >= 119
x = 0
y = 0


[State 0, ChangeState]
type = ChangeState
trigger1 = time > 120
value = 1610
ctrl = 0


;Level 1 Sonic Wind Ground to Air Transition (236236P)
