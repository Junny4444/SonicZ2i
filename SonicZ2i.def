;Denis:
;Cliff Portrait
;Mini Portrait (also with some help from HB and Plus.)
;Win portrait

;SonicHalo3435:
;Gotenks Drawing

;HB Productions:
;Tails Tornado Sprite
;Sonic Dashing Sprite during Shadow outro
;Walk back Sprite
;Run Back Sprite
;Old Emo Bar


;Ohmga Shironeko
;New Emo Bar

;Skipper
;Shock Sprite Outlines


;Funky Dunkerz
;Slight Sprite edits to crouch

;Modd
;Scary Sonic Sprite


;GadgetMcFly:
;Ring Burst Anim
;Piggy (also with help from HB)
;Rabbit
;Midnight Bliss

pal.defaults = 1,2,3,4,5,6,7
localcoord = 320,240

;====================================================================
;FILES FOR THE PLAYER

[Files]
sprite  = files/sprite.sff
anim    = files/animation.air
sound   = files/sound.snd
cmd     = files/command.mfg
cns     = states/constants.cns
st	= states/system.cns
st2	= states/helpers.cns
st3	= states/state-2-3.cns
st4	= states/override.cns
st5       = states/normals.cns
st6	= states/specials.cns
st7	= states/supers.cns
st8	= config.txt
st9 = states/emotion.cns
st0 = states/finishers.cns
;st10 = NOTES.txt
stcommon = common1.cns

;====================================================================
;PALETTES
; Maps character selection buttons to palette numbers.
[Palette Keymap]
x = 4 ;Press button X to select palette 1, etc.
y = 5
z = 6
a = 1
b = 2
c = 3
x2 = 10 ;Hold Start and press button X for palette 7, etc.
y2 = 11
z2 = 12
a2 = 7
b2 = 8
c2 = 9


; Arcade mode
;[Arcade]
;intro.storyboard = intro.def
;ending.storyboard = ending.def
