; Definition file for Sonic Z2i

;====================================================================
; PLAYER INFORMATION

[Info]
name = "Sonic Z2i"
displayname = "Sonic"
versiondate = 07,14,2013
mugenversion = 1.0
author = "Team Z2" ;Junny is author, Yoshin helped me a lot with stuff
;Team Z2 is for compatability
;Credits to Hypersonic for CVTW Sonic sprites
;Credit to Sega for the Sonic Advance FX and Sonic voices/SFX
;Some SFX also from Super Smash Bros. Brawl
pal.defaults = 1,2,3,4,5,6,7
localcoord = 320,240

;====================================================================
;FILES FOR THE PLAYER

[Files]
sprite  = files/sprite.sff
anim    = files/animation.air
sound   = files/sound.snd
cmd     = files/command.mfg
cns     = states/constants.cns
st	= states/system.cns
st2	= states/helpers.cns
st3	= states/state-2-3.cns
st4	= states/override.cns
st5       = states/normals.cns
st6	= states/specials.cns
st7	= states/supers.cns
st8	= config.txt
st9 = states/emotion.cns
stcommon = common1.cns

;====================================================================
;PALETTES
; Maps character selection buttons to palette numbers.
[Palette Keymap]
x = 4 ;Press button X to select palette 1, etc.
y = 5
z = 6
a = 1
b = 2
c = 3
x2 = 10 ;Hold Start and press button X for palette 7, etc.
y2 = 11
z2 = 12
a2 = 7
b2 = 8
c2 = 9


; Arcade mode
;[Arcade]
;intro.storyboard = intro.def
;ending.storyboard = ending.def
