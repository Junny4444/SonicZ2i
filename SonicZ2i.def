; Definition file for Sonic Z2i

;====================================================================
; PLAYER INFORMATION

[Info]
name = "Sonic Z2i"
displayname = "Sonic"
versiondate = 07,14,2013 ;Started development late September 2024
mugenversion = 1.0
author = "Team Z2" ;Junny is author, Yoshin helped me a lot with some code snippets
;Team Z2 is for compatability
;Credits to Hypersonic for CVTW Sonic sprites
;Credits to SeanAlty for a few code snippets
;Credit to Sega for the Sonic Advance FX and Sonic voices/SFX
;Some SFX also from Super Smash Bros. Brawl
;Credits to some random Deviantart user I forgot for rocket sprites
;Thanks to Coldnfox for balance feedback
;Rank icons by HammerBro101 on Deviantart





;Sprite Credits



;Nome De Gente:
